[Unit]
Description=Calibration Certificate Generator API
After=network-online.target

[Container]
Image=localhost/calibration-certificate-generator:latest
PublishPort=8000:8000
EnvironmentFile=%h/.config/containers/calibration-certificate-generator.env
Volume=calibration-certificate-generator-data:/app/data:Z


[Service]
Restart=always
TimeoutStartSec=30

[Install]
WantedBy=default.target
