# ─── Application ───
APP_NAME="Calibration Cert Generator"
APP_URL=https://lab.softreck.dev
DOMAIN=lab.softreck.dev
APP_ENV=prod

# ─── oqlos integration ───
OQLOS_URL=https://oqlos.softreck.dev
OQLOS_API_KEY=

# ─── Signing (PAdES) ───
# Ścieżka do pliku PKCS#12 z kluczem podpisującym
SIGNING_KEY_PATH=/run/secrets/signing.p12
SIGNING_KEY_PASSWORD=
VERIFY_BASE_URL=https://lab.softreck.dev/verify/

# ─── SMTP ───
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
SMTP_USER=lab@softreck.dev
SMTP_PASS=
SMTP_FROM="Softreck Lab <lab@softreck.dev>"

# ─── Webhook from oqlos ───
WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# ─── JWT for web UI ───
JWT_SECRET=generate_with_openssl_rand_hex_32

# ─── TLS ───
LE_EMAIL=ops@softreck.dev

# ─── Notifications ───
QUALITY_MANAGER_EMAIL=quality@softreck.dev
COMPLIANCE_EMAIL=compliance@softreck.dev

# ─── DATA.organization overrides ───
# Nadpisze pola w data/organization.json jeśli `env_overrides: true`
ORG_NAME="Softreck Calibration Lab"
ORG_CITY=Gdańsk
