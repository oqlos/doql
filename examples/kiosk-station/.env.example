# ─── Station identity ───
STATION_ID=WS-01
STATION_NAME="Warsztat 1"
DOMAIN=kiosk-01.lan

# ─── oqlos integration ───
OQLOS_URL=https://oqlos.softreck.dev
OQLOS_API_KEY=

# ─── Local storage ───
KIOSK_DATA_DIR=/var/lib/kiosk
KIOSK_USER=kiosk_ro

# ─── Service contact ───
SERVICE_PHONE=+48123456789
SERVICE_EMAIL=support@softreck.dev

# ─── OTA updates ───
OTA_ENABLED=true
OTA_CHANNEL=stable
OTA_PUBLIC_KEY_URL=https://updates.softreck.dev/kiosk.pub

# ─── Hardware config ───
PRINTER_DEVICE=/dev/ttyUSB0
PRINTER_DPI=203
BARCODE_SCANNER_TIMEOUT_MS=100

# ─── Idle / session ───
IDLE_TIMEOUT_SECONDS=180
SESSION_MAX_HOURS=8
PIN_LOCKOUT_ATTEMPTS=5

# ─── Telemetry (opcjonalnie) ───
TELEMETRY_ENDPOINT=https://oqlos.softreck.dev/kiosks/telemetry
TELEMETRY_INTERVAL_MINUTES=5
