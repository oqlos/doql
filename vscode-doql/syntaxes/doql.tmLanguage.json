{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "doql",
  "scopeName": "source.doql",
  "patterns": [
    { "include": "#comments" },
    { "include": "#top-level-keywords" },
    { "include": "#field-keywords" },
    { "include": "#env-refs" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.doql"
    },
    "top-level-keywords": {
      "match": "^\\s*(APP|VERSION|DOMAIN|AUTHOR|LANGUAGES|DEFAULT_LANGUAGE|ENTITY|DATA|TEMPLATE|DOCUMENT|REPORT|DATABASE|API_CLIENT|WEBHOOK|INTERFACE|INTEGRATION|WORKFLOW|ROLES|ROLE|SCENARIOS|TESTS|DEPLOY|PAGE|PERMISSIONS)\\b",
      "captures": {
        "1": { "name": "keyword.control.doql" }
      }
    },
    "field-keywords": {
      "match": "\\b(type|required|unique|default|computed|ref|description|example|format|min|max|enum|trigger|schedule|condition|steps|from|layout|features|source|event|auth|secret|base_url|token|retry|timeout|target|rootless)\\b\\s*:",
      "captures": {
        "1": { "name": "entity.name.tag.doql" }
      }
    },
    "env-refs": {
      "match": "\\benv\\.([A-Z_][A-Z0-9_]*)\\b",
      "captures": {
        "0": { "name": "variable.other.env.doql" },
        "1": { "name": "variable.other.constant.doql" }
      }
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.doql",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.doql" }
          ]
        },
        {
          "name": "string.quoted.single.doql",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "numbers": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.doql"
    },
    "types": {
      "match": "\\b(string|int|integer|float|decimal|bool|boolean|date|datetime|timestamp|json|uuid|email|url|text|blob)\\b",
      "name": "storage.type.doql"
    }
  }
}
