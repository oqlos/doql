# ──────────────────────────────────────────────
# Mask Inspection Manager — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# --- Application ---
APP_NAME="Mask Inspection Manager"
APP_URL=https://scba.example.com
APP_ENV=prod          # dev | staging | prod

# --- Database ---
DATABASE_URL=postgresql://oqlos:changeme@db:5432/scba
DATABASE_POOL_SIZE=10

# --- Auth ---
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRE_MINUTES=480
SESSION_SECRET=generate_another_hex_32

# SSO (opcjonalne)
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
SSO_MICROSOFT_TENANT=

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bot@example.com
SMTP_PASS=
SMTP_FROM="SCBA Manager <bot@example.com>"

# --- Slack ---
SLACK_WEBHOOK=https://hooks.slack.com/services/...

# --- FCM Push (mobile) ---
FCM_SERVER_KEY=
FCM_SENDER_ID=

# --- S3 / MinIO Storage ---
S3_BUCKET=scba-assets
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Label Printer (Zebra) ---
LABEL_PRINTER_URL=http://printer.local:9100

# --- oqlos integration ---
OQLOS_URL=http://oqlos-api:8000
OQLOS_API_KEY=
WEBHOOK_SECRET=generate_hex_32
NOTIFICATION_WEBHOOK=http://doql-backend:8001/webhooks/oqlos

# --- TLS (Let's Encrypt) ---
LE_EMAIL=admin@example.com

# --- Backup ---
BACKUP_REPO=s3:s3.amazonaws.com/my-backups
RESTIC_PASSWORD=generate_strong_password

# --- Monitoring ---
SENTRY_DSN=
PROMETHEUS_ENABLED=true
