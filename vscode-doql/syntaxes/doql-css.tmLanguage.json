{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "doql CSS",
  "scopeName": "source.doql.css",
  "patterns": [
    { "include": "#comments" },
    { "include": "#variables" },
    { "include": "#selectors" },
    { "include": "#blocks" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.doql",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.doql",
          "match": "//.*$"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.less.doql",
          "match": "@[a-zA-Z_][a-zA-Z0-9_-]*"
        },
        {
          "name": "variable.other.sass.doql",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_-]*"
        }
      ]
    },
    "selectors": {
      "patterns": [
        {
          "name": "entity.name.tag.doql",
          "match": "\\b(app|entity|interface|data|template|document|report|database|api_client|webhook|workflow|integration|deploy|roles|role|scenarios)\\b"
        },
        {
          "name": "entity.other.attribute-name.doql",
          "match": "\\[name=\"[^\"]*\"\\]"
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "keyword.other.doql",
          "match": "\\b(uuid|string|text|int|decimal|bool|date|datetime|email|json|pdf|image|enum|ref|auto|unique|computed|default)\\b"
        },
        {
          "name": "constant.language.doql",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "string.quoted.double.doql",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "constant.numeric.doql",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        },
        {
          "name": "keyword.operator.doql",
          "match": "!"
        },
        {
          "name": "support.type.property-name.doql",
          "match": "^\\s*[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*:)"
        }
      ]
    }
  }
}
